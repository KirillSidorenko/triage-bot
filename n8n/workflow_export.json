      "typeVersion": 4.5,
      "position": [1580, 60],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets"
        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $('Normalize Input').item.json.chat_id }}",
        "text": "={{ '✅ Обращение принято!\\n\\n📋 Категория: ' + $json.category + '\\n⚡ Приоритет: ' + $json.priority + '\\n👥 Направлено: ' + $json.route + '\\n\\nВаше обращение обрабатывается.' }}",
        "additionalFields": {
          "parse_mode": "HTML"
