            "timestamp": "={{ $('Normalize Input').item.json.timestamp }}",
            "sender": "={{ $('Normalize Input').item.json.sender }}",
            "original_message": "={{ $('Normalize Input').item.json.text }}",
            "summary": "={{ $json.summary }}",
            "category": "={{ $json.category }}",
            "priority": "={{ $json.priority }}",
            "confidence": "={{ $json.confidence }}",
            "route": "={{ $json.route }}",
            "needs_review": "true",
            "reviewer_decision": "",
            "final_category": "",
            "processing_time_ms": "={{ $json.processing_time_ms }}"
          }
        }
