    },
    {
      "parameters": {
        "chatId": "={{ $('Normalize Input').item.json.chat_id }}",
        "text": "✅ Обращение принято!\n\nВаш запрос передан на рассмотрение специалисту. Мы свяжемся с вами в ближайшее время.",
        "additionalFields": {
          "parse_mode": "HTML"
        }
      },
      "id": "node-telegram-confirm-review",
      "name": "Telegram — Confirm (Review)",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1800, 0],
      "credentials": {
        "telegramApi": {
          "id": "TELEGRAM_CREDENTIAL_ID",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $env.REVIEWER_CHAT_ID }}",
        "text": "={{ '🔍 Требуется review\\n\\nОт: ' + $('Normalize Input').item.json.sender + '\\n\\nСообщение: ' + $('Normalize Input').item.json.text + '\\n\\nAI предложил:\\n- Категория: ' + $json.category + '\\n- Приоритет: ' + $json.priority + '\\n- Confidence: ' + $json.confidence + '\\n- Summary: ' + $json.summary + (($json.priority === 'critical') ? '\\n\\n🚨 CRITICAL — требуется немедленная реакция' : '') }}",
        "additionalFields": {
          "parse_mode": "HTML"
